# Entra OAuth configuration for bill_analysis_mcp
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Azure Entra ID tenant ID (found in Azure Portal → Entra ID → Overview)
ENTRA_TENANT_ID=your-tenant-id-here

# App registration client ID (Azure Portal → App Registrations → your app → Overview)
ENTRA_CLIENT_ID=your-client-id-here

# App registration client secret (Azure Portal → App Registrations → your app → Certificates & secrets)
ENTRA_CLIENT_SECRET=your-client-secret-here

# Consolidated MCP URL configuration
# Base URL of this MCP server — used for both public access and OAuth callback.
# The value of {MCP_URL}/callback MUST be registered as a redirect URI
# in your app registration (Azure Portal → App Registrations → your app → Authentication).
# This port MUST match the --port argument (default: 3000).
MCP_URL=http://localhost:3000
